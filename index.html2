<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>Dai Surf Forecast</title>

<style>
body {
  font-family: Arial;
  text-align: center;
  background: linear-gradient(#00c6ff, #0072ff);
  color: white;
  padding: 40px;
}

button {
  padding: 15px 25px;
  font-size: 18px;
  border: none;
  border-radius: 10px;
  background: #ffcc00;
  cursor: pointer;
}

.wave-container {
  margin-top: 40px;
  height: 200px;
  overflow: hidden;
  position: relative;
}

.wave {
  position: absolute;
  width: 200%;
  height: 100%;
  background: rgba(255,255,255,0.5);
  border-radius: 40%;
  animation: none;
}

@keyframes waveMove {
  0% { transform: translateX(0) translateY(0); }
  50% { transform: translateX(-25%) translateY(-20px); }
  100% { transform: translateX(-50%) translateY(0); }
}

.small { height: 50px; }
.medium { height: 100px; }
.big { height: 160px; }

</style>
</head>

<body>

<h1>🏄 Dai Surf Forecast</h1>
<p>Pererenan</p>

<button onclick="showWave()">今日の波予想</button>

<div class="wave-container">
  <div id="wave" class="wave"></div>
</div>

<p id="result"></p>

<script>
function showWave() {
  const wave = document.getElementById("wave");
  const result = document.getElementById("result");

  const waves = [
    {size: "小波", class: "small"},
    {size: "胸〜肩", class: "medium"},
    {size: "頭オーバー", class: "big"}
  ];

  const random = waves[Math.floor(Math.random() * waves.length)];

  wave.className = "wave " + random.class;
  wave.style.animation = "waveMove 3s infinite linear";

  result.innerHTML = "今日の波：" + random.size;
}
</script>

</body>
</html>
